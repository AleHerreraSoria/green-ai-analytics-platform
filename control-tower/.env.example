# Control Tower -> Airflow (cross-instance)
AIRFLOW_API_BASE_URL=https://replace-airflow-domain
AIRFLOW_API_USERNAME=replace-service-user
AIRFLOW_API_PASSWORD=replace-service-password
# AIRFLOW_API_TOKEN=replace-api-token
# Opcional: valor completo de Authorization (prioridad sobre token y user/pass). Ej. Bearer eyJ... o Basic base64
# AIRFLOW_API_AUTHORIZATION=
# Desactivar login web automático (FAB) para obtener cookie de sesión en la API (por defecto activo con user/pass)
# AIRFLOW_API_DISABLE_FAB_SESSION=
AIRFLOW_API_TIMEOUT_SECONDS=10

# Pipeline monitored by Control Tower
PIPELINE_DAG_ID=green-ai-full-pipeline
# Mostrar botón «Ejecutar pipeline ahora» en Pipeline Live (POST a la API; requiere permisos en Airflow)
# PIPELINE_ALLOW_MANUAL_TRIGGER=true
AIRFLOW_POLL_INTERVAL_SECONDS=6
STREAM_HEARTBEAT_SECONDS=2
