# Environment identifier
APP_ENV=dev

# AWS provider chain context
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-only-for-local-dev
AWS_SECRET_ACCESS_KEY=replace-only-for-local-dev

# Spark jobs configuration (required)
S3_BRONZE_BUCKET=replace-bronze-bucket
S3_SILVER_BUCKET=replace-silver-bucket
S3_GOLD_BUCKET=replace-gold-bucket
